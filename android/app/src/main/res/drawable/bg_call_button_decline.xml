<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the call-decline / hangup buttons. Solid red oval
    with a press-state ripple so taps give immediate visual feedback.
    The <mask> child clips the ripple to the oval bounds instead of
    the rectangular ImageButton hit box; the second child is the
    resting-state fill (identical to the pre-ripple <shape>).
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/incoming_call_decline" />
        </shape>
    </item>
</ripple>
